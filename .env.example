# ── Backend ───────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# API key required on every request (leave empty to disable auth in dev)
NEURALSEED_API_KEY=

# Comma-separated list of allowed origins (CORS)
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TRIBE_API_BASE_URL=http://localhost:8000/api/v1/diagnostics

# Must match NEURALSEED_API_KEY above (leave empty if auth is disabled)
NEXT_PUBLIC_API_KEY=
